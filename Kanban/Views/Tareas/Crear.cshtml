@model Kanban.ViewModels.Tareas.CrearTareaViewModel

@{
    ViewData["Title"] = "Crear Tarea";

}
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
    </div>
}

<div class="container mt-4">
    <div class="kanban-card" style="max-width: 600px; margin: 0 auto; background-color: #f8f9fa;">
        <h2 class="mb-4">Nueva Tarea</h2>
        
        <form asp-action="Crear">
            <input type="hidden" asp-for="IdTablero" value="@Model.IdTablero" />
            
            <div class="form-group">
                <label asp-for="Nombre"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Nombre de la tarea" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Descripcion"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Descripción detallada"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Color"></label>
                        <input type="color" asp-for="Color" class="form-control" style="height: 40px; padding: 2px;" />
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Estado"></label>
                        <select asp-for="Estado" class="form-control" asp-items="Html.GetEnumSelectList<EstadoTarea>()"></select>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label>Asignar a:</label>
                <select asp-for="IdUsuarioAsignado" class="form-control">
                    <option value="">Sin asignar</option>
                    @if (Model.UsuariosDisponibles != null)
                    {
                        @foreach (var usuario in Model.UsuariosDisponibles)
                        {
                            <option value="@usuario.id">@usuario.nombreDeUsuario</option>
                        }
                    }
                </select>
            </div>

            <div class="mt-4 text-right">
                <button type="submit" class="btn btn-custom">
                    <i class="fas fa-save"></i> Crear
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        .kanban-card {
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}