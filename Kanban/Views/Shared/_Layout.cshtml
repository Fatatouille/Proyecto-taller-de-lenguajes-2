@using Microsoft.AspNetCore.Http

@{
    var rolUsuario = ViewContext.HttpContext.Session.GetString("Rol") ?? "";
    var rutaActual = ViewContext.RouteData.Values["action"].ToString().ToLower();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kanban</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Kanban.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <style>
        .navbar-custom {
            background-color: #563d7c;
        }
        .navbar-custom .navbar-brand,
        .navbar-custom .nav-link {
            color: white;
        }
        .container-custom {
            margin-top: 20px;
        }
        .btn-custom {
            background-color: #563d7c;
            color: white;
        }
        .btn-custom:hover {
            background-color: #452a63;
        }
        .kanban-board {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
        }
        .kanban-column {
            flex: 1;
            margin: 0 10px;
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 4px;
            max-width: 300px;
        }
        .kanban-column-header {
            background-color: #343a40;
            color: white;
            text-align: center;
            padding: 10px;
            border-top-left-radius: 4px;
            border-top-right-radius: 4px;
        }
        .kanban-column-body {
            padding: 10px;
        }
        .kanban-item {
            background-color: #ffeb3b;
            border: 1px solid #ffeb3b;
            padding: 10px;
            margin-bottom: 10px;
            border-radius: 4px;
        }
        input{
            margin:.5em;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-custom border-bottom box-shadow mb-3">
            <div class="container-fluid">
                @if (string.IsNullOrEmpty(rolUsuario))
                {
                    <a class="navbar-brand" href="@Url.Action("Login", "Login")">Kanban</a>
                }
                else
                {
                    <a class="navbar-brand" asp-controller="Tableros" asp-action="Index">Kanban</a>
                }

                @if (!string.IsNullOrEmpty(rolUsuario))
                {
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between" id="navbarNav">
                        <ul class="navbar-nav flex-grow-1">
                            @if (rolUsuario == "Administrador")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Tableros" asp-action="Index">Tableros</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Usuarios" asp-action="Index">Usuarios</a>
                                </li>
                            }
                            else if (rolUsuario == "Operador")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Tableros" asp-action="Index">Todos los Tableros</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Tableros" asp-action="MisTableros">Mis Tableros</a>
                                </li>
                            }
                        </ul>
                        @if (rutaActual != "login")
                        {
                            <ul class="navbar-nav">
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Login" asp-action="Logout">Cerrar Sesión</a>
                                </li>
                            </ul>
                        }
                    </div>
                }
            </div>
        </nav>
    </header>
        
    <div class="container container-custom">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Kanban - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>