@model Kanban.ViewModels.Usuarios.ListarUsuariosViewModel

@{
    ViewData["Title"] = "Lista de Usuarios";
}

<div class="container mt-4">
    <h2>Lista de Usuarios</h2>

    <div class="row mb-3">
        <div class="col text-right">
            <a href="@Url.Action("Crear", "Usuarios")" class="btn btn-success">Crear Nuevo Usuario</a>
        </div>
    </div>

    <table class="table table-striped table-hover">
        <thead class="thead-dark">
            <tr>
                <th>Id</th>
                <th>Nombre de Usuario</th>
                <th>Rol</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var usuario in Model.Usuarios)
            {
                <tr>
                    <td>@usuario.Id</td>
                    <td>@usuario.NombreDeUsuario</td>
                    <td>@usuario.Rol</td>
                    <td>
                        <a href="@Url.Action("Editar", "Usuarios", new { id = usuario.Id })" class="btn btn-warning btn-sm">Editar</a>
                        <form asp-action="Eliminar" method="post" asp-controller="Usuarios" asp-route-id="@usuario.Id" class="d-inline" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este usuario?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
